{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "environmentVariableRedaction": {
      "enabled": true
    },
    "disableYoloMode": true,
    "enablePermanentToolApproval": true,
    "blockGitExtensions": true,
    "enableConseca": false
  },
  "ui": {
    "theme": "ANSI Light",
    "autoThemeSwitching": false,
    "showStatusInTitle": false,
    "hideBanner": true,
    "footer": {
      "hideContextPercentage": false,
      "showLabels": false,
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "model-name",
        "context-used",
        "quota",
        "token-count"
      ]
    },
    "showCitations": true,
    "showSpinner": false,
    "hideWindowTitle": true,
    "accessibility": {
      "enableLoadingPhrases": false
    },
    "loadingPhrases": "off",
    "hideTips": true
  },
  "general": {
    "previewFeatures": true,
    "defaultApprovalMode": "auto_edit",
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "10d"
    },
    "plan": {
      "directory": ""
    }
  },
  "tools": {},
  "model": {
    "name": "auto-gemini-3",
    "compressionThreshold": 0.45
  },
  "billing": {
    "overageStrategy": "never"
  },
  "advanced": {
    "autoConfigureMemory": true
  },
  "experimental": {
    "toolOutputMasking": {
      "enabled": true
    },
    "useOSC52Paste": true,
    "modelSteering": true,
    "plan": true
  },
  "skills": {
    "enabled": false
  },
  "hooksConfig": {
    "enabled": false
  }
}