{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "environmentVariableRedaction": {
      "enabled": true
    },
    "disableYoloMode": true
  },
  "ui": {
    "theme": "ANSI Light",
    "autoThemeSwitching": false,
    "showStatusInTitle": false,
    "hideBanner": true,
    "footer": {
      "hideContextPercentage": false,
      "showLabels": false,
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "model-name",
        "context-used",
        "quota",
        "token-count"
      ]
    },
    "showCitations": true,
    "showSpinner": false,
    "hideWindowTitle": true,
    "accessibility": {
      "enableLoadingPhrases": false
    },
    "loadingPhrases": "off"
  },
  "general": {
    "previewFeatures": true,
    "defaultApprovalMode": "auto_edit",
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "30d"
    }
  },
  "tools": {},
  "model": {
    "name": "auto-gemini-3",
    "compressionThreshold": 0.45
  }
}